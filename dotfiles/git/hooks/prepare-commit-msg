#!/usr/bin/env bash
# Global prepare-commit-msg hook: strip AI-attribution trailers before editing.
# Installed by ns-bootstrap — applies to all repositories.
# Belt-and-suspenders with commit-msg hook (which runs after editing).

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SCRIPT_DIR/lib/strip-ai-trailers.sh"
strip_ai_trailers "$1"
